[gd_resource type="Resource" script_class="Recipe" load_steps=5 format=3]

[ext_resource type="Script" path="res://common/items/recipe.gd" id="1_script"]
[ext_resource type="Resource" path="res://common/items/instances/Semi-Elaborate/standard_timber.tres" id="2_timber"]
[ext_resource type="Resource" path="res://common/items/instances/Semi-Elaborate/wooden_pegs.tres" id="3_pegs"]
[ext_resource type="Resource" path="res://common/items/instances/Finished Goods/basic_crate.tres" id="4_crate"]

[resource]
