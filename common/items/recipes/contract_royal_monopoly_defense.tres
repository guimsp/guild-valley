[ext_resource type="Resource" path="res://common/items/instances/Finished Goods/royal_tapestry.tres" id="4_tapestry"]
[ext_resource type="Resource" path="res://common/items/instances/Finished Goods/monopoly_defense_contract.tres" id="5_contract"]

[resource]
script = ExtResource("1_script")
