[gd_resource type="Resource" script_class="Recipe" load_steps=7 format=3]

[ext_resource type="Script" path="res://common/items/recipe.gd" id="1_script"]
[ext_resource type="Resource" path="res://common/items/instances/Finished Goods/savory_baked_eggs.tres" id="2_eggs"]
[ext_resource type="Resource" path="res://common/items/instances/Finished Goods/baked_apples.tres" id="3_apples"]
[ext_resource type="Resource" path="res://common/items/instances/Finished Goods/ale.tres" id="4_ale"]
[ext_resource type="Resource" path="res://common/items/instances/Finished Goods/noble_event_certificate.tres" id="5_cert"]

[resource]
script = ExtResource("1_script")
recipe_name = "Host Noble Merchant Gala"
required_career = "patreon"
required_level = 8
inputs = {
ExtResource("2_eggs"): 5,
ExtResource("3_apples"): 5,
ExtResource("4_ale"): 5
}
